# --- Canvas connection ---
# Your institution's Canvas base URL, e.g. https://canvas.instructure.com
# or https://yourschool.instructure.com
CANVAS_BASE_URL=https://canvas.instructure.com

# How to authenticate to Canvas:
#   browser = log in through a real browser session (works even when your
#             district disables access tokens). DEFAULT.
#   token   = use a personal access token (only if your school allows them).
AUTH_MODE=browser

# Where the persistent browser login session is stored (browser mode).
CANVAS_PROFILE_DIR=.canvas_profile

# Personal access token: Canvas -> Account -> Settings -> "+ New Access Token"
# Only needed when AUTH_MODE=token. Leave blank for browser mode.
CANVAS_TOKEN=

# --- Brain (LLM) ---
# Which provider drives the agent: "ollama" (local, default) or "anthropic" (cloud).
LLM_PROVIDER=ollama

# Ollama (local) settings
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Anthropic (optional, only used if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Safety ---
# Write behavior: dry_run | confirm | auto
# dry_run  = never writes, just logs what it would do (safest; default)
# confirm  = shows you the exact content and waits for y/n
# auto     = posts without asking (graded work is ALWAYS forced to confirm)
WRITE_MODE=dry_run
