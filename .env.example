# --- Canvas connection ---
# Your institution's Canvas base URL, e.g. https://canvas.instructure.com
# or https://yourschool.instructure.com
CANVAS_BASE_URL=https://canvas.instructure.com

# How to authenticate to Canvas:
#   browser = log in through a real browser session (works even when your
#             district disables access tokens). DEFAULT.
#   token   = use a personal access token (only if your school allows them).
AUTH_MODE=browser

# Where the persistent browser login session is stored (browser mode).
CANVAS_PROFILE_DIR=.canvas_profile

# Personal access token: Canvas -> Account -> Settings -> "+ New Access Token"
# Only needed when AUTH_MODE=token. Leave blank for browser mode.
CANVAS_TOKEN=

# --- Brain (LLM) ---
# Provider for the chat/agent AND drafting. Options:
#   claude_code  = your Claude Pro/Max SUBSCRIPTION via the Claude Code CLI
#                  (counts against your chat plan, NOT API credits). DEFAULT.
#                  Requires Claude Code installed + logged in once with `claude`.
#   ollama       = local, free (needs Ollama + a downloaded model)
#   anthropic    = Anthropic API (separate pay-as-you-go API credits + key below)
LLM_PROVIDER=claude_code

# Provider used ONLY for drafting/explaining ("Do it for me", reply drafts).
# Defaults to LLM_PROVIDER; same options as above.
DRAFT_PROVIDER=claude_code

# Optional model for claude_code (blank = subscription default, e.g. opus).
CLAUDE_CODE_MODEL=

# --- Make drafts sound like YOU ---
# Everything written for you already avoids common "AI tells". To go further and
# mimic your own voice, paste a paragraph or two of your real writing into a file
# named voice.txt in this folder (git-ignored). Or paste a short sample here:
WRITING_SAMPLE=

# Ollama (local) settings
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Anthropic / Claude (used when a provider above is "anthropic").
# Get a key at https://console.anthropic.com. claude-opus-4-8 is highest quality;
# claude-haiku-4-5 is much cheaper and fine for drafting.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Study-first ---
# Canvas-AI is a study & drafting tool by default. Submitting or auto-doing
# graded work (assignments, discussion replies, quizzes) is hidden and disabled
# unless you turn this on. Off by default.
ALLOW_SUBMIT=false

# --- Safety ---
# Write behavior: dry_run | confirm | auto
# dry_run  = never writes, just logs what it would do (safest; default)
# confirm  = shows you the exact content and waits for y/n
# auto     = posts without asking (graded work needs AUTO_SUBMIT below)
WRITE_MODE=dry_run

# Let the assistant complete AND submit graded assignments directly, with no
# per-submission confirmation. Off by default. When true, the "Do it for me"
# button writes and submits your work in one click. Your account, your work —
# check your school's academic-integrity policy before enabling this.
AUTO_SUBMIT=false
