# Canvas-AI distribution defaults — baked into the sellable exe.
# Contains NO personal info: no Canvas URL, no login, no keys, no writing sample.
# Each buyer sets their Canvas URL and signs in from the app's Setup tab.

AUTH_MODE=browser

# Default brain = the user's own Claude subscription (configured in-app).
LLM_PROVIDER=claude_code
DRAFT_PROVIDER=claude_code
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
ANTHROPIC_MODEL=claude-opus-4-8

# Study-first: submitting/auto-doing graded work is off by default.
WRITE_MODE=dry_run
AUTO_SUBMIT=false
ALLOW_SUBMIT=false

# Licensing: set to true when you're ready to SELL (then the exe requires a
# license key to run). Leave false while testing so you aren't locked out.
LICENSE_REQUIRED=false

# Optional: URL to version.json for the in-app update banner.
UPDATE_URL=
